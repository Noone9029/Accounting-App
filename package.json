{
  "name": "ledgerbyte",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "dev": "corepack pnpm -r --parallel --if-present dev",
    "build": "corepack pnpm -r --if-present build",
    "test": "corepack pnpm -r --if-present test",
    "lint": "corepack pnpm -r --if-present lint",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "verify:diff": "node scripts/verify-gate.cjs verify:diff",
    "verify:local:web": "node scripts/verify-gate.cjs verify:local:web",
    "verify:local:api": "node scripts/verify-gate.cjs verify:local:api",
    "verify:local:guards": "node scripts/verify-gate.cjs verify:local:guards",
    "verify:repo": "node scripts/verify-gate.cjs verify:repo",
    "verify:ci:local": "node scripts/verify-gate.cjs verify:ci:local",
    "fixture:dev04:plan": "corepack pnpm --filter @ledgerbyte/api fixture:dev04 -- --plan",
    "fixture:dev04:dry-run": "corepack pnpm --filter @ledgerbyte/api fixture:dev04 -- --dry-run",
    "fixture:dev04:cleanup-plan": "corepack pnpm --filter @ledgerbyte/api fixture:dev04 -- --cleanup-plan",
    "cleanup:dev08m:ap:plan": "corepack pnpm --filter @ledgerbyte/api cleanup:dev08m:ap -- --plan",
    "cleanup:dev08m:ap:dry-run": "corepack pnpm --filter @ledgerbyte/api cleanup:dev08m:ap -- --dry-run",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "test:visual": "playwright test -c playwright.visual.config.ts",
    "demo:seed-workflows": "corepack pnpm --filter @ledgerbyte/api demo:seed-workflows",
    "user-testing:cleanup-plan": "node scripts/user-testing-cleanup-plan.cjs",
    "test:user-testing-cleanup-plan": "node --test scripts/user-testing-cleanup-plan.test.cjs",
    "postinstall": "node scripts/vercel-postinstall.cjs",
    "smoke:accounting": "corepack pnpm --filter @ledgerbyte/api smoke:accounting",
    "smoke:accounting:banking": "corepack pnpm --filter @ledgerbyte/api smoke:accounting:banking",
    "smoke:accounting:tail": "corepack pnpm --filter @ledgerbyte/api smoke:accounting:tail",
    "smoke:accounting:ar": "corepack pnpm --filter @ledgerbyte/api smoke:accounting:ar",
    "smoke:accounting:ap": "corepack pnpm --filter @ledgerbyte/api smoke:accounting:ap",
    "smoke:accounting:documents": "corepack pnpm --filter @ledgerbyte/api smoke:accounting:documents",
    "smoke:accounting:reports": "corepack pnpm --filter @ledgerbyte/api smoke:accounting:reports",
    "smoke:accounting:zatca-safe": "corepack pnpm --filter @ledgerbyte/api smoke:accounting:zatca-safe",
    "zatca:validate-generated": "node scripts/validate-generated-zatca-invoice.cjs",
    "zatca:debug-pih-chain": "node scripts/debug-zatca-pih-chain.cjs",
    "zatca:validate-sdk-hash-mode": "node scripts/validate-zatca-sdk-hash-mode.cjs",
    "zatca:csr-dry-run": "corepack pnpm --filter @ledgerbyte/api zatca:csr-dry-run",
    "zatca:csr-local-generate": "corepack pnpm --filter @ledgerbyte/api zatca:csr-local-generate",
    "zatca:local-signing-dry-run": "corepack pnpm --filter @ledgerbyte/api zatca:local-signing-dry-run",
    "zatca:local-signed-xml-validate": "corepack pnpm --filter @ledgerbyte/api zatca:local-signed-xml-validate",
    "zatca:compliance-csid-plan": "corepack pnpm --filter @ledgerbyte/api zatca:compliance-csid-plan",
    "zatca:compliance-csid-dry-run": "corepack pnpm --filter @ledgerbyte/api zatca:compliance-csid-dry-run",
    "zatca:compliance-csid-custody-plan": "corepack pnpm --filter @ledgerbyte/api zatca:compliance-csid-custody-plan",
    "db:generate": "corepack pnpm --filter @ledgerbyte/api db:generate",
    "db:migrate": "corepack pnpm --filter @ledgerbyte/api db:migrate",
    "db:seed": "corepack pnpm --filter @ledgerbyte/api db:seed"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "typescript": "^5.8.3"
  }
}

{
  "name": "ledgerbyte",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "dev": "corepack pnpm -r --parallel --if-present dev",
    "build": "corepack pnpm -r --if-present build",
    "test": "corepack pnpm -r --if-present test",
    "lint": "corepack pnpm -r --if-present lint",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "postinstall": "node scripts/vercel-postinstall.cjs",
    "smoke:accounting": "corepack pnpm --filter @ledgerbyte/api smoke:accounting",
    "zatca:validate-generated": "node scripts/validate-generated-zatca-invoice.cjs",
    "zatca:debug-pih-chain": "node scripts/debug-zatca-pih-chain.cjs",
    "zatca:validate-sdk-hash-mode": "node scripts/validate-zatca-sdk-hash-mode.cjs",
    "zatca:csr-dry-run": "corepack pnpm --filter @ledgerbyte/api zatca:csr-dry-run",
    "zatca:csr-local-generate": "corepack pnpm --filter @ledgerbyte/api zatca:csr-local-generate",
    "zatca:local-signing-dry-run": "corepack pnpm --filter @ledgerbyte/api zatca:local-signing-dry-run",
    "db:generate": "corepack pnpm --filter @ledgerbyte/api db:generate",
    "db:migrate": "corepack pnpm --filter @ledgerbyte/api db:migrate",
    "db:seed": "corepack pnpm --filter @ledgerbyte/api db:seed"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "typescript": "^5.8.3"
  }
}

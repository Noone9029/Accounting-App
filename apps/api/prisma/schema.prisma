generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  COST_OF_SALES
}

enum ContactType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum TaxRateScope {
  SALES
  PURCHASES
  BOTH
}

enum TaxRateCategory {
  STANDARD
  ZERO_RATED
  EXEMPT
  OUT_OF_SCOPE
  REVERSE_CHARGE
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOIDED
  REVERSED
}

enum ItemType {
  SERVICE
  PRODUCT
}

enum ItemStatus {
  ACTIVE
  DISABLED
}

enum SalesInvoiceStatus {
  DRAFT
  FINALIZED
  VOIDED
}

enum CreditNoteStatus {
  DRAFT
  FINALIZED
  VOIDED
}

enum PurchaseBillStatus {
  DRAFT
  FINALIZED
  VOIDED
}

enum CustomerPaymentStatus {
  DRAFT
  POSTED
  VOIDED
}

enum SupplierPaymentStatus {
  DRAFT
  POSTED
  VOIDED
}

enum CustomerRefundStatus {
  DRAFT
  POSTED
  VOIDED
}

enum CustomerRefundSourceType {
  CUSTOMER_PAYMENT
  CREDIT_NOTE
}

enum DocumentType {
  SALES_INVOICE
  CREDIT_NOTE
  CUSTOMER_PAYMENT_RECEIPT
  CUSTOMER_REFUND
  CUSTOMER_STATEMENT
  PURCHASE_BILL
  SUPPLIER_PAYMENT_RECEIPT
}

enum GeneratedDocumentStatus {
  GENERATED
  FAILED
  SUPERSEDED
}

enum ZatcaEnvironment {
  SANDBOX
  SIMULATION
  PRODUCTION
}

enum ZatcaRegistrationStatus {
  NOT_CONFIGURED
  DRAFT
  READY_FOR_CSR
  OTP_REQUIRED
  CERTIFICATE_ISSUED
  ACTIVE
  SUSPENDED
}

enum ZatcaInvoiceType {
  STANDARD_TAX_INVOICE
  SIMPLIFIED_TAX_INVOICE
  CREDIT_NOTE
  DEBIT_NOTE
}

enum ZatcaInvoiceStatus {
  NOT_SUBMITTED
  XML_GENERATED
  READY_FOR_SUBMISSION
  SUBMISSION_PENDING
  CLEARED
  REPORTED
  REJECTED
  FAILED
}

enum ZatcaSubmissionType {
  COMPLIANCE_CHECK
  CLEARANCE
  REPORTING
}

enum ZatcaSubmissionStatus {
  PENDING
  SUCCESS
  REJECTED
  FAILED
}

enum FiscalPeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum NumberSequenceScope {
  JOURNAL_ENTRY
  INVOICE
  BILL
  PAYMENT
  CUSTOMER_REFUND
  CREDIT_NOTE
  DEBIT_NOTE
  CONTACT
}

model User {
  id                      String               @id @default(uuid()) @db.Uuid
  email                   String               @unique
  passwordHash            String
  name                    String
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  memberships             OrganizationMember[]
  createdLogs             AuditLog[]           @relation("AuditActor")
  postedEntries           JournalEntry[]       @relation("PostedBy")
  createdEntries          JournalEntry[]       @relation("CreatedBy")
  createdSalesInvoices    SalesInvoice[]       @relation("SalesInvoiceCreatedBy")
  createdCreditNotes      CreditNote[]         @relation("CreditNoteCreatedBy")
  createdPurchaseBills    PurchaseBill[]       @relation("PurchaseBillCreatedBy")
  createdCustomerPayments CustomerPayment[]    @relation("CustomerPaymentCreatedBy")
  createdSupplierPayments SupplierPayment[]    @relation("SupplierPaymentCreatedBy")
  createdCustomerRefunds  CustomerRefund[]     @relation("CustomerRefundCreatedBy")
  reversedCreditNoteAllocations CreditNoteAllocation[] @relation("CreditNoteAllocationReversedBy")
  reversedCustomerPaymentUnappliedAllocations CustomerPaymentUnappliedAllocation[] @relation("CustomerPaymentUnappliedAllocationReversedBy")
  generatedDocuments      GeneratedDocument[]  @relation("GeneratedDocumentGeneratedBy")
}

model Organization {
  id                         String                      @id @default(uuid()) @db.Uuid
  name                       String
  legalName                  String?
  taxNumber                  String?
  countryCode                String                      @default("SA")
  baseCurrency               String                      @default("SAR")
  timezone                   String                      @default("Asia/Riyadh")
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  memberships                OrganizationMember[]
  roles                      Role[]
  branches                   Branch[]
  contacts                   Contact[]
  accounts                   Account[]
  taxRates                   TaxRate[]
  items                      Item[]
  salesInvoices              SalesInvoice[]
  salesInvoiceLines          SalesInvoiceLine[]
  creditNotes                CreditNote[]
  creditNoteLines            CreditNoteLine[]
  creditNoteAllocations      CreditNoteAllocation[]
  purchaseBills              PurchaseBill[]
  purchaseBillLines          PurchaseBillLine[]
  customerPayments           CustomerPayment[]
  customerPaymentAllocations CustomerPaymentAllocation[]
  customerPaymentUnappliedAllocations CustomerPaymentUnappliedAllocation[]
  supplierPayments           SupplierPayment[]
  supplierPaymentAllocations SupplierPaymentAllocation[]
  customerRefunds            CustomerRefund[]
  journalEntries             JournalEntry[]
  journalLines               JournalLine[]
  fiscalPeriods              FiscalPeriod[]
  auditLogs                  AuditLog[]
  numberSequences            NumberSequence[]
  documentSettings           OrganizationDocumentSettings?
  generatedDocuments         GeneratedDocument[]
  zatcaProfile               ZatcaOrganizationProfile?
  zatcaEgsUnits              ZatcaEgsUnit[]
  zatcaInvoiceMetadata       ZatcaInvoiceMetadata[]
  zatcaSubmissionLogs        ZatcaSubmissionLog[]
}

model OrganizationDocumentSettings {
  id                       String       @id @default(uuid()) @db.Uuid
  organizationId           String       @unique @db.Uuid
  invoiceTitle             String       @default("Tax Invoice")
  receiptTitle             String       @default("Payment Receipt")
  statementTitle           String       @default("Customer Statement")
  footerText               String       @default("Generated by LedgerByte")
  primaryColor             String?
  accentColor              String?
  showTaxNumber            Boolean      @default(true)
  showPaymentSummary       Boolean      @default(true)
  showNotes                Boolean      @default(true)
  showTerms                Boolean      @default(true)
  defaultInvoiceTemplate   String       @default("standard")
  defaultReceiptTemplate   String       @default("standard")
  defaultStatementTemplate String       @default("standard")
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model GeneratedDocument {
  id              String                  @id @default(uuid()) @db.Uuid
  organizationId  String                  @db.Uuid
  documentType    DocumentType
  sourceType      String
  sourceId        String
  documentNumber  String
  filename        String
  mimeType        String                  @default("application/pdf")
  storageProvider String                  @default("database")
  storageKey      String?
  contentBase64   String?                 @db.Text
  contentHash     String
  sizeBytes       Int
  status          GeneratedDocumentStatus @default(GENERATED)
  generatedById   String?                 @db.Uuid
  generatedAt     DateTime                @default(now())
  createdAt       DateTime                @default(now())
  organization    Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generatedBy     User?                   @relation("GeneratedDocumentGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, documentType])
  @@index([organizationId, sourceType, sourceId])
  @@index([organizationId, status])
  @@index([generatedById])
}

model ZatcaOrganizationProfile {
  id                      String                  @id @default(uuid()) @db.Uuid
  organizationId          String                  @unique @db.Uuid
  environment             ZatcaEnvironment        @default(SANDBOX)
  registrationStatus      ZatcaRegistrationStatus @default(NOT_CONFIGURED)
  sellerName              String?
  vatNumber               String?
  companyIdType           String?
  companyIdNumber         String?
  buildingNumber          String?
  streetName              String?
  district                String?
  city                    String?
  postalCode              String?
  countryCode             String                  @default("SA")
  additionalAddressNumber String?
  businessCategory        String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  organization            Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  egsUnits                ZatcaEgsUnit[]

  @@index([organizationId])
}

model ZatcaEgsUnit {
  id                   String                  @id @default(uuid()) @db.Uuid
  organizationId       String                  @db.Uuid
  profileId            String                  @db.Uuid
  name                 String
  environment          ZatcaEnvironment
  status               ZatcaRegistrationStatus @default(DRAFT)
  deviceSerialNumber   String
  solutionName         String                  @default("LedgerByte")
  csrPem               String?                 @db.Text
  /// TODO: production must store private keys in a secrets manager/KMS, not in the database.
  privateKeyPem        String?                 @db.Text
  complianceCsidPem    String?                 @db.Text
  productionCsidPem    String?                 @db.Text
  certificateRequestId String?
  lastInvoiceHash      String?
  lastIcv              Int                     @default(0)
  isActive             Boolean                 @default(false)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  organization         Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  profile              ZatcaOrganizationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  invoiceMetadata      ZatcaInvoiceMetadata[]
  submissionLogs       ZatcaSubmissionLog[]

  @@unique([organizationId, deviceSerialNumber])
  @@index([organizationId])
  @@index([profileId])
  @@index([organizationId, isActive])
}

model ZatcaInvoiceMetadata {
  id                  String             @id @default(uuid()) @db.Uuid
  organizationId      String             @db.Uuid
  invoiceId           String             @unique @db.Uuid
  zatcaInvoiceType    ZatcaInvoiceType
  zatcaStatus         ZatcaInvoiceStatus @default(NOT_SUBMITTED)
  invoiceUuid         String             @unique @default(uuid()) @db.Uuid
  icv                 Int?
  previousInvoiceHash String?
  invoiceHash         String?
  qrCodeBase64        String?            @db.Text
  xmlBase64           String?            @db.Text
  xmlHash             String?
  egsUnitId           String?            @db.Uuid
  generatedAt         DateTime?
  clearedAt           DateTime?
  reportedAt          DateTime?
  rejectedAt          DateTime?
  lastErrorCode       String?
  lastErrorMessage    String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice             SalesInvoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  egsUnit             ZatcaEgsUnit?      @relation(fields: [egsUnitId], references: [id], onDelete: SetNull)
  submissionLogs      ZatcaSubmissionLog[]

  @@index([organizationId])
  @@index([organizationId, zatcaStatus])
  @@index([egsUnitId])
}

model ZatcaSubmissionLog {
  id                   String                 @id @default(uuid()) @db.Uuid
  organizationId       String                 @db.Uuid
  invoiceMetadataId    String?                @db.Uuid
  egsUnitId            String?                @db.Uuid
  submissionType       ZatcaSubmissionType
  status               ZatcaSubmissionStatus
  requestUrl           String?
  requestPayloadBase64 String?                @db.Text
  responsePayloadBase64 String?               @db.Text
  responseCode         String?
  errorCode            String?
  errorMessage         String?
  submittedAt          DateTime               @default(now())
  completedAt          DateTime?
  createdAt            DateTime               @default(now())
  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceMetadata      ZatcaInvoiceMetadata?  @relation(fields: [invoiceMetadataId], references: [id], onDelete: Cascade)
  egsUnit              ZatcaEgsUnit?          @relation(fields: [egsUnitId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([invoiceMetadataId])
  @@index([egsUnitId])
  @@index([organizationId, status])
}

model Role {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @db.Uuid
  name           String
  permissions    Json
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        OrganizationMember[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model OrganizationMember {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid
  userId         String           @db.Uuid
  roleId         String           @db.Uuid
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role             @relation(fields: [roleId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
}

model Branch {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid
  name           String
  displayName    String?
  phone          String?
  taxNumber      String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  countryCode    String         @default("SA")
  postalCode     String?
  isDefault      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesInvoices  SalesInvoice[]
  creditNotes    CreditNote[]
  purchaseBills  PurchaseBill[]

  @@index([organizationId])
}

model Contact {
  id               String            @id @default(uuid()) @db.Uuid
  organizationId   String            @db.Uuid
  type             ContactType       @default(CUSTOMER)
  name             String
  displayName      String?
  email            String?
  phone            String?
  taxNumber        String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  countryCode      String            @default("SA")
  postalCode       String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesInvoices    SalesInvoice[]    @relation("SalesInvoiceCustomer")
  creditNotes      CreditNote[]      @relation("CreditNoteCustomer")
  purchaseBills    PurchaseBill[]    @relation("PurchaseBillSupplier")
  customerPayments CustomerPayment[] @relation("CustomerPaymentCustomer")
  supplierPayments SupplierPayment[] @relation("SupplierPaymentSupplier")
  customerRefunds  CustomerRefund[]  @relation("CustomerRefundCustomer")

  @@index([organizationId])
  @@index([organizationId, type])
}

model Account {
  id                String             @id @default(uuid()) @db.Uuid
  organizationId    String             @db.Uuid
  parentId          String?            @db.Uuid
  code              String
  name              String
  type              AccountType
  description       String?
  allowPosting      Boolean            @default(true)
  isSystem          Boolean            @default(false)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent            Account?           @relation("AccountTree", fields: [parentId], references: [id])
  children          Account[]          @relation("AccountTree")
  journalLines      JournalLine[]
  itemRevenueItems  Item[]             @relation("ItemRevenueAccount")
  itemExpenseItems  Item[]             @relation("ItemExpenseAccount")
  salesInvoiceLines SalesInvoiceLine[]
  creditNoteLines   CreditNoteLine[]
  purchaseBillLines PurchaseBillLine[]
  customerPayments  CustomerPayment[]  @relation("CustomerPaymentAccount")
  supplierPayments  SupplierPayment[]  @relation("SupplierPaymentAccount")
  customerRefunds   CustomerRefund[]   @relation("CustomerRefundAccount")

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([parentId])
}

model TaxRate {
  id                   String             @id @default(uuid()) @db.Uuid
  organizationId       String             @db.Uuid
  name                 String
  scope                TaxRateScope
  category             TaxRateCategory
  rate                 Decimal            @db.Decimal(7, 4)
  description          String?
  isActive             Boolean            @default(true)
  isSystem             Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  journalLines         JournalLine[]
  itemSalesTaxItems    Item[]             @relation("ItemSalesTaxRate")
  itemPurchaseTaxItems Item[]             @relation("ItemPurchaseTaxRate")
  salesInvoiceLines    SalesInvoiceLine[]
  creditNoteLines      CreditNoteLine[]
  purchaseBillLines    PurchaseBillLine[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Item {
  id                String             @id @default(uuid()) @db.Uuid
  organizationId    String             @db.Uuid
  name              String
  description       String?
  sku               String?
  type              ItemType
  status            ItemStatus         @default(ACTIVE)
  sellingPrice      Decimal            @db.Decimal(20, 4)
  revenueAccountId  String             @db.Uuid
  salesTaxRateId    String?            @db.Uuid
  purchaseCost      Decimal?           @db.Decimal(20, 4)
  expenseAccountId  String?            @db.Uuid
  purchaseTaxRateId String?            @db.Uuid
  inventoryTracking Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  revenueAccount    Account            @relation("ItemRevenueAccount", fields: [revenueAccountId], references: [id])
  salesTaxRate      TaxRate?           @relation("ItemSalesTaxRate", fields: [salesTaxRateId], references: [id], onDelete: SetNull)
  expenseAccount    Account?           @relation("ItemExpenseAccount", fields: [expenseAccountId], references: [id])
  purchaseTaxRate   TaxRate?           @relation("ItemPurchaseTaxRate", fields: [purchaseTaxRateId], references: [id])
  salesInvoiceLines SalesInvoiceLine[]
  creditNoteLines   CreditNoteLine[]
  purchaseBillLines PurchaseBillLine[]

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([revenueAccountId])
  @@index([salesTaxRateId])
}

model SalesInvoice {
  id                     String                      @id @default(uuid()) @db.Uuid
  organizationId         String                      @db.Uuid
  invoiceNumber          String
  customerId             String                      @db.Uuid
  branchId               String?                     @db.Uuid
  issueDate              DateTime
  dueDate                DateTime?
  currency               String                      @default("SAR")
  status                 SalesInvoiceStatus          @default(DRAFT)
  subtotal               Decimal                     @default(0) @db.Decimal(20, 4)
  discountTotal          Decimal                     @default(0) @db.Decimal(20, 4)
  taxableTotal           Decimal                     @default(0) @db.Decimal(20, 4)
  taxTotal               Decimal                     @default(0) @db.Decimal(20, 4)
  total                  Decimal                     @default(0) @db.Decimal(20, 4)
  balanceDue             Decimal                     @default(0) @db.Decimal(20, 4)
  notes                  String?
  terms                  String?
  createdById            String?                     @db.Uuid
  finalizedAt            DateTime?
  journalEntryId         String?                     @unique @db.Uuid
  reversalJournalEntryId String?                     @unique @db.Uuid
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  organization           Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer               Contact                     @relation("SalesInvoiceCustomer", fields: [customerId], references: [id])
  branch                 Branch?                     @relation(fields: [branchId], references: [id])
  createdBy              User?                       @relation("SalesInvoiceCreatedBy", fields: [createdById], references: [id])
  journalEntry           JournalEntry?               @relation("SalesInvoiceJournal", fields: [journalEntryId], references: [id])
  reversalJournalEntry   JournalEntry?               @relation("SalesInvoiceReversalJournal", fields: [reversalJournalEntryId], references: [id])
  lines                  SalesInvoiceLine[]
  paymentAllocations     CustomerPaymentAllocation[]
  paymentUnappliedAllocations CustomerPaymentUnappliedAllocation[]
  creditNoteAllocations  CreditNoteAllocation[]
  creditNotes            CreditNote[]
  zatcaMetadata          ZatcaInvoiceMetadata?

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([customerId])
  @@index([status])
}

model SalesInvoiceLine {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @db.Uuid
  invoiceId       String       @db.Uuid
  itemId          String?      @db.Uuid
  description     String
  accountId       String       @db.Uuid
  quantity        Decimal      @db.Decimal(20, 4)
  unitPrice       Decimal      @db.Decimal(20, 4)
  discountRate    Decimal      @default(0) @db.Decimal(7, 4)
  taxRateId       String?      @db.Uuid
  lineGrossAmount Decimal      @default(0) @db.Decimal(20, 4)
  discountAmount  Decimal      @default(0) @db.Decimal(20, 4)
  taxableAmount   Decimal      @default(0) @db.Decimal(20, 4)
  taxAmount       Decimal      @default(0) @db.Decimal(20, 4)
  lineSubtotal    Decimal      @default(0) @db.Decimal(20, 4)
  lineTotal       Decimal      @default(0) @db.Decimal(20, 4)
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice         SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item            Item?        @relation(fields: [itemId], references: [id], onDelete: SetNull)
  account         Account      @relation(fields: [accountId], references: [id])
  taxRate         TaxRate?     @relation(fields: [taxRateId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([invoiceId])
  @@index([itemId])
  @@index([accountId])
}

model CreditNote {
  id                     String           @id @default(uuid()) @db.Uuid
  organizationId         String           @db.Uuid
  creditNoteNumber       String
  customerId             String           @db.Uuid
  originalInvoiceId      String?          @db.Uuid
  branchId               String?          @db.Uuid
  issueDate              DateTime
  currency               String           @default("SAR")
  status                 CreditNoteStatus @default(DRAFT)
  subtotal               Decimal          @default(0) @db.Decimal(20, 4)
  discountTotal          Decimal          @default(0) @db.Decimal(20, 4)
  taxableTotal           Decimal          @default(0) @db.Decimal(20, 4)
  taxTotal               Decimal          @default(0) @db.Decimal(20, 4)
  total                  Decimal          @default(0) @db.Decimal(20, 4)
  unappliedAmount        Decimal          @default(0) @db.Decimal(20, 4)
  notes                  String?
  reason                 String?
  createdById            String?          @db.Uuid
  finalizedAt            DateTime?
  journalEntryId         String?          @unique @db.Uuid
  reversalJournalEntryId String?          @unique @db.Uuid
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  organization           Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer               Contact          @relation("CreditNoteCustomer", fields: [customerId], references: [id])
  originalInvoice        SalesInvoice?    @relation(fields: [originalInvoiceId], references: [id], onDelete: SetNull)
  branch                 Branch?          @relation(fields: [branchId], references: [id])
  createdBy              User?            @relation("CreditNoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  journalEntry           JournalEntry?    @relation("CreditNoteJournal", fields: [journalEntryId], references: [id])
  reversalJournalEntry   JournalEntry?    @relation("CreditNoteReversalJournal", fields: [reversalJournalEntryId], references: [id])
  lines                  CreditNoteLine[]
  allocations            CreditNoteAllocation[]
  refunds                CustomerRefund[] @relation("CustomerRefundCreditNote")

  @@unique([organizationId, creditNoteNumber])
  @@index([organizationId])
  @@index([customerId])
  @@index([originalInvoiceId])
  @@index([status])
}

model CreditNoteLine {
  id              String      @id @default(uuid()) @db.Uuid
  organizationId  String      @db.Uuid
  creditNoteId    String      @db.Uuid
  itemId          String?     @db.Uuid
  description     String
  accountId       String      @db.Uuid
  quantity        Decimal     @db.Decimal(20, 4)
  unitPrice       Decimal     @db.Decimal(20, 4)
  discountRate    Decimal     @default(0) @db.Decimal(7, 4)
  taxRateId       String?     @db.Uuid
  lineGrossAmount Decimal     @default(0) @db.Decimal(20, 4)
  discountAmount  Decimal     @default(0) @db.Decimal(20, 4)
  taxableAmount   Decimal     @default(0) @db.Decimal(20, 4)
  taxAmount       Decimal     @default(0) @db.Decimal(20, 4)
  lineTotal       Decimal     @default(0) @db.Decimal(20, 4)
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creditNote      CreditNote   @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  item            Item?        @relation(fields: [itemId], references: [id], onDelete: SetNull)
  account         Account      @relation(fields: [accountId], references: [id])
  taxRate         TaxRate?     @relation(fields: [taxRateId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([creditNoteId])
  @@index([itemId])
  @@index([accountId])
}

model CreditNoteAllocation {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  creditNoteId   String       @db.Uuid
  invoiceId      String       @db.Uuid
  amountApplied  Decimal      @db.Decimal(20, 4)
  reversedAt     DateTime?
  reversedById   String?      @db.Uuid
  reversalReason String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creditNote     CreditNote   @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  invoice        SalesInvoice @relation(fields: [invoiceId], references: [id])
  reversedBy     User?        @relation("CreditNoteAllocationReversedBy", fields: [reversedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([creditNoteId])
  @@index([invoiceId])
  @@index([reversedAt])
  @@index([reversedById])
}

model PurchaseBill {
  id                     String             @id @default(uuid()) @db.Uuid
  organizationId         String             @db.Uuid
  billNumber             String
  supplierId             String             @db.Uuid
  branchId               String?            @db.Uuid
  billDate               DateTime
  dueDate                DateTime?
  currency               String             @default("SAR")
  status                 PurchaseBillStatus @default(DRAFT)
  subtotal               Decimal            @default(0) @db.Decimal(20, 4)
  discountTotal          Decimal            @default(0) @db.Decimal(20, 4)
  taxableTotal           Decimal            @default(0) @db.Decimal(20, 4)
  taxTotal               Decimal            @default(0) @db.Decimal(20, 4)
  total                  Decimal            @default(0) @db.Decimal(20, 4)
  balanceDue             Decimal            @default(0) @db.Decimal(20, 4)
  notes                  String?
  terms                  String?
  createdById            String?            @db.Uuid
  finalizedAt            DateTime?
  journalEntryId         String?            @unique @db.Uuid
  reversalJournalEntryId String?            @unique @db.Uuid
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  organization           Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier               Contact            @relation("PurchaseBillSupplier", fields: [supplierId], references: [id])
  branch                 Branch?            @relation(fields: [branchId], references: [id])
  createdBy              User?              @relation("PurchaseBillCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  journalEntry           JournalEntry?      @relation("PurchaseBillJournal", fields: [journalEntryId], references: [id])
  reversalJournalEntry   JournalEntry?      @relation("PurchaseBillReversalJournal", fields: [reversalJournalEntryId], references: [id])
  lines                  PurchaseBillLine[]
  paymentAllocations     SupplierPaymentAllocation[]

  @@unique([organizationId, billNumber])
  @@index([organizationId])
  @@index([supplierId])
  @@index([status])
}

model PurchaseBillLine {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @db.Uuid
  billId          String       @db.Uuid
  itemId          String?      @db.Uuid
  description     String
  accountId       String       @db.Uuid
  quantity        Decimal      @db.Decimal(20, 4)
  unitPrice       Decimal      @db.Decimal(20, 4)
  discountRate    Decimal      @default(0) @db.Decimal(7, 4)
  taxRateId       String?      @db.Uuid
  lineGrossAmount Decimal      @default(0) @db.Decimal(20, 4)
  discountAmount  Decimal      @default(0) @db.Decimal(20, 4)
  taxableAmount   Decimal      @default(0) @db.Decimal(20, 4)
  taxAmount       Decimal      @default(0) @db.Decimal(20, 4)
  lineTotal       Decimal      @default(0) @db.Decimal(20, 4)
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bill            PurchaseBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  item            Item?        @relation(fields: [itemId], references: [id], onDelete: SetNull)
  account         Account      @relation(fields: [accountId], references: [id])
  taxRate         TaxRate?     @relation(fields: [taxRateId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([billId])
  @@index([itemId])
  @@index([accountId])
}

model CustomerPayment {
  id                         String                      @id @default(uuid()) @db.Uuid
  organizationId             String                      @db.Uuid
  paymentNumber              String
  customerId                 String                      @db.Uuid
  paymentDate                DateTime
  currency                   String                      @default("SAR")
  status                     CustomerPaymentStatus       @default(POSTED)
  amountReceived             Decimal                     @db.Decimal(20, 4)
  unappliedAmount            Decimal                     @default(0) @db.Decimal(20, 4)
  description                String?
  accountId                  String                      @db.Uuid
  journalEntryId             String?                     @unique @db.Uuid
  voidReversalJournalEntryId String?                     @unique @db.Uuid
  createdById                String?                     @db.Uuid
  postedAt                   DateTime?
  voidedAt                   DateTime?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  organization               Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer                   Contact                     @relation("CustomerPaymentCustomer", fields: [customerId], references: [id])
  account                    Account                     @relation("CustomerPaymentAccount", fields: [accountId], references: [id])
  journalEntry               JournalEntry?               @relation("CustomerPaymentJournal", fields: [journalEntryId], references: [id])
  voidReversalJournalEntry   JournalEntry?               @relation("CustomerPaymentVoidReversalJournal", fields: [voidReversalJournalEntryId], references: [id])
  createdBy                  User?                       @relation("CustomerPaymentCreatedBy", fields: [createdById], references: [id])
  allocations                CustomerPaymentAllocation[]
  unappliedAllocations       CustomerPaymentUnappliedAllocation[]
  refunds                    CustomerRefund[]            @relation("CustomerRefundPayment")

  @@unique([organizationId, paymentNumber])
  @@index([organizationId])
  @@index([customerId])
  @@index([status])
}

model CustomerPaymentAllocation {

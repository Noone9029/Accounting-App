  @@index([organizationId])
  @@index([organizationId, status])
  @@index([requestedById])
  @@index([requestId])
}

model ImportJob {
  id               String          @id @default(uuid()) @db.Uuid
  organizationId   String          @db.Uuid
  entityType       ImportEntityType
  status           ImportJobStatus @default(UPLOADED)
  filename         String
  sourceKind       String          @default("LOCAL_CSV_UPLOAD")
  previewOnly      Boolean         @default(true)
  summaryJson      Json
  requestId        String?
  createdById      String?         @db.Uuid
  committedById    String?         @db.Uuid
  committedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy        User?           @relation("ImportJobCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  committedBy      User?           @relation("ImportJobCommittedBy", fields: [committedById], references: [id], onDelete: SetNull)
  rows             ImportJobRow[]
  validationIssues ImportValidationIssue[]

  @@index([organizationId, entityType, status])
  @@index([organizationId, createdAt])
}

model ImportJobRow {
  id               String             @id @default(uuid()) @db.Uuid
  organizationId   String             @db.Uuid
  importJobId      String             @db.Uuid

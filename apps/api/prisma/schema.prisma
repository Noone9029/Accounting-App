model JournalEntry {
  id                    String             @id @default(uuid()) @db.Uuid
  organizationId        String             @db.Uuid
  entryNumber           String
  status                JournalEntryStatus @default(DRAFT)
  entryDate             DateTime
  description           String
  reference             String?
  currency              String             @default("SAR")
  totalDebit            Decimal            @default(0) @db.Decimal(20, 4)
  totalCredit           Decimal            @default(0) @db.Decimal(20, 4)
  postedAt              DateTime?
  postedById            String?            @db.Uuid
  createdById           String?            @db.Uuid
  reversalOfId          String?            @unique @db.Uuid
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  organization          Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  postedBy              User?              @relation("PostedBy", fields: [postedById], references: [id])
  createdBy             User?              @relation("CreatedBy", fields: [createdById], references: [id])
  reversalOf            JournalEntry?      @relation("JournalReversal", fields: [reversalOfId], references: [id])
  reversedBy            JournalEntry?      @relation("JournalReversal")
  salesInvoice          SalesInvoice?      @relation("SalesInvoiceJournal")
  voidedSalesInvoice    SalesInvoice?      @relation("SalesInvoiceReversalJournal")
  creditNote            CreditNote?        @relation("CreditNoteJournal")
  voidedCreditNote      CreditNote?        @relation("CreditNoteReversalJournal")
  purchaseBill          PurchaseBill?      @relation("PurchaseBillJournal")
  voidedPurchaseBill    PurchaseBill?      @relation("PurchaseBillReversalJournal")
  purchaseDebitNote     PurchaseDebitNote? @relation("PurchaseDebitNoteJournal")
  voidedPurchaseDebitNote PurchaseDebitNote? @relation("PurchaseDebitNoteReversalJournal")
  cashExpense           CashExpense?       @relation("CashExpenseJournal")
  voidedCashExpense     CashExpense?       @relation("CashExpenseVoidReversalJournal")
  customerPayment       CustomerPayment?   @relation("CustomerPaymentJournal")
  voidedCustomerPayment CustomerPayment?   @relation("CustomerPaymentVoidReversalJournal")
  supplierPayment       SupplierPayment?   @relation("SupplierPaymentJournal")
  voidedSupplierPayment SupplierPayment?   @relation("SupplierPaymentVoidReversalJournal")
  customerRefund        CustomerRefund?    @relation("CustomerRefundJournal")
  voidedCustomerRefund  CustomerRefund?    @relation("CustomerRefundVoidReversalJournal")
  supplierRefund        SupplierRefund?    @relation("SupplierRefundJournal")
  voidedSupplierRefund  SupplierRefund?    @relation("SupplierRefundVoidReversalJournal")
  bankTransfer          BankTransfer?      @relation("BankTransferJournal")
  voidedBankTransfer    BankTransfer?      @relation("BankTransferVoidReversalJournal")
  bankAccountOpeningProfile BankAccountProfile? @relation("BankAccountOpeningBalanceJournal")
  matchedBankStatementTransactions BankStatementTransaction[] @relation("BankStatementTransactionMatchedJournalEntry")
  createdBankStatementTransactions BankStatementTransaction[] @relation("BankStatementTransactionCreatedJournalEntry")
  lines                 JournalLine[]

  @@unique([organizationId, entryNumber])
  @@index([organizationId])
  @@index([status])
}

model JournalLine {
  id             String       @id @default(uuid()) @db.Uuid

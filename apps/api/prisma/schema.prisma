model OrganizationDocumentSettings {
  id                       String       @id @default(uuid()) @db.Uuid
  organizationId           String       @unique @db.Uuid
  invoiceTitle             String       @default("Tax Invoice")
  receiptTitle             String       @default("Payment Receipt")
  statementTitle           String       @default("Customer Statement")
  footerText               String       @default("Generated by LedgerByte")
  primaryColor             String?
  accentColor              String?
  showTaxNumber            Boolean      @default(true)
  showPaymentSummary       Boolean      @default(true)
  showNotes                Boolean      @default(true)
  showTerms                Boolean      @default(true)
  defaultInvoiceTemplate   String       @default("standard")
  defaultReceiptTemplate   String       @default("standard")
  defaultStatementTemplate String       @default("standard")
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model InventorySettings {
  id                               String                       @id @default(uuid()) @db.Uuid
  organizationId                   String                       @unique @db.Uuid
  valuationMethod                  InventoryValuationMethod     @default(MOVING_AVERAGE)
  allowNegativeStock               Boolean                      @default(false)
  trackInventoryValue              Boolean                      @default(true)
  enableInventoryAccounting        Boolean                      @default(false)
  inventoryAssetAccountId          String?                      @db.Uuid
  cogsAccountId                    String?                      @db.Uuid
  inventoryClearingAccountId       String?                      @db.Uuid
  inventoryAdjustmentGainAccountId String?                      @db.Uuid
  inventoryAdjustmentLossAccountId String?                      @db.Uuid
  purchaseReceiptPostingMode       InventoryPurchasePostingMode @default(DISABLED)
  createdAt                        DateTime                     @default(now())
  updatedAt                        DateTime                     @updatedAt
  organization                     Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryAssetAccount            Account?                     @relation("InventorySettingsInventoryAssetAccount", fields: [inventoryAssetAccountId], references: [id], onDelete: SetNull)
  cogsAccount                      Account?                     @relation("InventorySettingsCogsAccount", fields: [cogsAccountId], references: [id], onDelete: SetNull)
  inventoryClearingAccount         Account?                     @relation("InventorySettingsInventoryClearingAccount", fields: [inventoryClearingAccountId], references: [id], onDelete: SetNull)
  inventoryAdjustmentGainAccount   Account?                     @relation("InventorySettingsAdjustmentGainAccount", fields: [inventoryAdjustmentGainAccountId], references: [id], onDelete: SetNull)
  inventoryAdjustmentLossAccount   Account?                     @relation("InventorySettingsAdjustmentLossAccount", fields: [inventoryAdjustmentLossAccountId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([inventoryAssetAccountId])
  @@index([cogsAccountId])
  @@index([inventoryClearingAccountId])
  @@index([inventoryAdjustmentGainAccountId])
  @@index([inventoryAdjustmentLossAccountId])
}

model GeneratedDocument {
  id              String                  @id @default(uuid()) @db.Uuid
  organizationId  String                  @db.Uuid
  documentType    DocumentType
  sourceType      String
  sourceId        String
  documentNumber  String
  filename        String
  mimeType        String                  @default("application/pdf")
  storageProvider String                  @default("database")
  storageKey      String?
  contentBase64   String?                 @db.Text
  contentHash     String
  sizeBytes       Int
  status          GeneratedDocumentStatus @default(GENERATED)
  requestId       String?
  generatedById   String?                 @db.Uuid
  generatedAt     DateTime                @default(now())
  createdAt       DateTime                @default(now())
  organization    Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generatedBy     User?                   @relation("GeneratedDocumentGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull)
  emailOutbox      EmailOutbox[]           @relation("EmailOutboxGeneratedDocument")

  @@index([organizationId])
  @@index([organizationId, documentType])
  @@index([organizationId, sourceType, sourceId])
  @@index([organizationId, status])
  @@index([requestId])
  @@index([generatedById])
}

model ReportPack {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid

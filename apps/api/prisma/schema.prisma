model CustomerRefund {
  id                         String                   @id @default(uuid()) @db.Uuid
  organizationId             String                   @db.Uuid
  refundNumber               String
  customerId                 String                   @db.Uuid
  sourceType                 CustomerRefundSourceType
  sourcePaymentId            String?                  @db.Uuid
  sourceCreditNoteId         String?                  @db.Uuid
  refundDate                 DateTime
  currency                   String                   @default("SAR")
  status                     CustomerRefundStatus     @default(POSTED)
  amountRefunded             Decimal                  @db.Decimal(20, 4)
  accountId                  String                   @db.Uuid
  description                String?
  journalEntryId             String?                  @unique @db.Uuid
  voidReversalJournalEntryId String?                  @unique @db.Uuid
  createdById                String?                  @db.Uuid
  postedAt                   DateTime?
  voidedAt                   DateTime?
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  organization               Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer                   Contact                  @relation("CustomerRefundCustomer", fields: [customerId], references: [id])

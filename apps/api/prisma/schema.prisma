model User {
  id                                                String                                      @id @default(uuid()) @db.Uuid
  email                                             String                                      @unique
  passwordHash                                      String
  name                                              String
  createdAt                                         DateTime                                    @default(now())
  updatedAt                                         DateTime                                    @updatedAt
  memberships                                       OrganizationMember[]
  createdLogs                                       AuditLog[]                                  @relation("AuditActor")
  postedEntries                                     JournalEntry[]                              @relation("PostedBy")
  createdEntries                                    JournalEntry[]                              @relation("CreatedBy")
  createdSalesInvoices                              SalesInvoice[]                              @relation("SalesInvoiceCreatedBy")
  createdSalesQuotes                                SalesQuote[]                                @relation("SalesQuoteCreatedBy")
  createdRecurringInvoiceTemplates                  RecurringInvoiceTemplate[]                  @relation("RecurringInvoiceTemplateCreatedBy")
  generatedRecurringInvoiceRuns                     RecurringInvoiceRun[]                       @relation("RecurringInvoiceRunGeneratedBy")
  createdDeliveryNotes                              DeliveryNote[]                              @relation("DeliveryNoteCreatedBy")
  createdSalesInventoryReturns                      SalesInventoryReturn[]                      @relation("SalesInventoryReturnCreatedBy")
  approvedSalesInventoryReturns                     SalesInventoryReturn[]                      @relation("SalesInventoryReturnApprovedBy")
  inventoryReturnPostedSalesInventoryReturns        SalesInventoryReturn[]                      @relation("SalesInventoryReturnInventoryPostedBy")
  assignedCollectionCases                           CollectionCase[]                            @relation("CollectionCaseAssignedTo")
  createdCollectionCases                            CollectionCase[]                            @relation("CollectionCaseCreatedBy")
  updatedCollectionCases                            CollectionCase[]                            @relation("CollectionCaseUpdatedBy")
  createdCollectionActivities                       CollectionActivity[]                        @relation("CollectionActivityCreatedBy")
  createdCreditNotes                                CreditNote[]                                @relation("CreditNoteCreatedBy")
  createdPurchaseOrders                             PurchaseOrder[]                             @relation("PurchaseOrderCreatedBy")
  createdPurchaseBills                              PurchaseBill[]                              @relation("PurchaseBillCreatedBy")
  createdPurchaseDebitNotes                         PurchaseDebitNote[]                         @relation("PurchaseDebitNoteCreatedBy")
  createdPurchaseReturns                            PurchaseReturn[]                            @relation("PurchaseReturnCreatedBy")
  approvedPurchaseReturns                           PurchaseReturn[]                            @relation("PurchaseReturnApprovedBy")
  inventoryReturnPostedPurchaseReturns              PurchaseReturn[]                            @relation("PurchaseReturnInventoryReturnPostedBy")
  createdCashExpenses                               CashExpense[]                               @relation("CashExpenseCreatedBy")
  createdCustomerPayments                           CustomerPayment[]                           @relation("CustomerPaymentCreatedBy")
  createdSupplierPayments                           SupplierPayment[]                           @relation("SupplierPaymentCreatedBy")
  createdCustomerRefunds                            CustomerRefund[]                            @relation("CustomerRefundCreatedBy")
  createdSupplierRefunds                            SupplierRefund[]                            @relation("SupplierRefundCreatedBy")
  createdBankTransfers                              BankTransfer[]                              @relation("BankTransferCreatedBy")
  importedBankStatements                            BankStatementImport[]                       @relation("BankStatementImportImportedBy")
  createdBankReconciliations                        BankReconciliation[]                        @relation("BankReconciliationCreatedBy")
  submittedBankReconciliations                      BankReconciliation[]                        @relation("BankReconciliationSubmittedBy")
  approvedBankReconciliations                       BankReconciliation[]                        @relation("BankReconciliationApprovedBy")
  reopenedBankReconciliations                       BankReconciliation[]                        @relation("BankReconciliationReopenedBy")
  closedBankReconciliations                         BankReconciliation[]                        @relation("BankReconciliationClosedBy")
  voidedBankReconciliations                         BankReconciliation[]                        @relation("BankReconciliationVoidedBy")
  bankReconciliationReviewEvents                    BankReconciliationReviewEvent[]             @relation("BankReconciliationReviewEventActor")

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  COST_OF_SALES
}

enum ContactType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum TaxRateScope {
  SALES
  PURCHASES
  BOTH
}

enum TaxRateCategory {
  STANDARD
  ZERO_RATED
  EXEMPT
  OUT_OF_SCOPE
  REVERSE_CHARGE
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOIDED
  REVERSED
}

enum ItemType {
  SERVICE
  PRODUCT
}

enum ItemStatus {
  ACTIVE
  DISABLED
}

enum SalesInvoiceStatus {
  DRAFT
  FINALIZED
  VOIDED
}

enum CreditNoteStatus {
  DRAFT
  FINALIZED
  VOIDED
}

enum PurchaseBillStatus {
  DRAFT
  FINALIZED
  VOIDED
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  SENT
  PARTIALLY_BILLED
  BILLED
  CLOSED
  VOIDED
}

enum PurchaseDebitNoteStatus {
  DRAFT
  FINALIZED
  VOIDED
}

enum CustomerPaymentStatus {
  DRAFT
  POSTED
  VOIDED
}

enum SupplierPaymentStatus {
  DRAFT
  POSTED
  VOIDED
}

enum CustomerRefundStatus {
  DRAFT
  POSTED
  VOIDED
}

enum CustomerRefundSourceType {
  CUSTOMER_PAYMENT
  CREDIT_NOTE
}

enum SupplierRefundStatus {
  DRAFT
  POSTED
  VOIDED
}

enum SupplierRefundSourceType {
  SUPPLIER_PAYMENT
  PURCHASE_DEBIT_NOTE
}

enum CashExpenseStatus {
  DRAFT
  POSTED
  VOIDED
}

enum BankAccountType {
  BANK
  CASH
  WALLET
  CARD
  OTHER
}

enum BankAccountStatus {
  ACTIVE
  ARCHIVED
}

enum BankTransferStatus {
  POSTED
  VOIDED
}

enum BankStatementImportStatus {
  IMPORTED
  PARTIALLY_RECONCILED
  RECONCILED
  VOIDED
}

enum BankStatementTransactionStatus {
  UNMATCHED
  MATCHED
  CATEGORIZED
  IGNORED
  VOIDED
}

enum BankStatementTransactionType {
  DEBIT
  CREDIT
}

enum BankStatementMatchType {
  JOURNAL_LINE
  MANUAL_JOURNAL
  CASH_EXPENSE
  CUSTOMER_PAYMENT
  SUPPLIER_PAYMENT
  CUSTOMER_REFUND
  SUPPLIER_REFUND
  BANK_TRANSFER
  OTHER
}

enum BankReconciliationStatus {
  DRAFT
  CLOSED
  VOIDED
}

enum DocumentType {
  SALES_INVOICE
  CREDIT_NOTE
  CUSTOMER_PAYMENT_RECEIPT
  CUSTOMER_REFUND
  CUSTOMER_STATEMENT
  PURCHASE_ORDER
  PURCHASE_BILL
  PURCHASE_DEBIT_NOTE
  SUPPLIER_PAYMENT_RECEIPT
  SUPPLIER_REFUND
  CASH_EXPENSE
  REPORT_GENERAL_LEDGER
  REPORT_TRIAL_BALANCE
  REPORT_PROFIT_AND_LOSS
  REPORT_BALANCE_SHEET
  REPORT_VAT_SUMMARY
  REPORT_AGED_RECEIVABLES
  REPORT_AGED_PAYABLES
  BANK_RECONCILIATION_REPORT
}

enum GeneratedDocumentStatus {
  GENERATED
  FAILED
  SUPERSEDED
}

enum ZatcaEnvironment {
  SANDBOX
  SIMULATION
  PRODUCTION
}

enum ZatcaRegistrationStatus {
  NOT_CONFIGURED
  DRAFT
  READY_FOR_CSR
  OTP_REQUIRED
  CERTIFICATE_ISSUED
  ACTIVE
  SUSPENDED
}

enum ZatcaInvoiceType {
  STANDARD_TAX_INVOICE
  SIMPLIFIED_TAX_INVOICE
  CREDIT_NOTE
  DEBIT_NOTE
}

enum ZatcaInvoiceStatus {
  NOT_SUBMITTED
  XML_GENERATED
  READY_FOR_SUBMISSION
  SUBMISSION_PENDING
  CLEARED
  REPORTED
  REJECTED
  FAILED
}

enum ZatcaSubmissionType {
  COMPLIANCE_CHECK
  CLEARANCE
  REPORTING
}

enum ZatcaSubmissionStatus {
  PENDING
  SUCCESS
  REJECTED
  FAILED
}

enum FiscalPeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum NumberSequenceScope {
  JOURNAL_ENTRY
  INVOICE
  BILL
  PAYMENT
  CUSTOMER_REFUND
  PURCHASE_ORDER
  BANK_TRANSFER
  CREDIT_NOTE
  DEBIT_NOTE
  PURCHASE_DEBIT_NOTE
  SUPPLIER_REFUND
  CASH_EXPENSE
  CONTACT
  BANK_RECONCILIATION
}

model User {
  id                      String               @id @default(uuid()) @db.Uuid
  email                   String               @unique
  passwordHash            String
  name                    String
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  memberships             OrganizationMember[]
  createdLogs             AuditLog[]           @relation("AuditActor")
  postedEntries           JournalEntry[]       @relation("PostedBy")
  createdEntries          JournalEntry[]       @relation("CreatedBy")
  createdSalesInvoices    SalesInvoice[]       @relation("SalesInvoiceCreatedBy")
  createdCreditNotes      CreditNote[]         @relation("CreditNoteCreatedBy")
  createdPurchaseOrders   PurchaseOrder[]      @relation("PurchaseOrderCreatedBy")
  createdPurchaseBills    PurchaseBill[]       @relation("PurchaseBillCreatedBy")
  createdPurchaseDebitNotes PurchaseDebitNote[] @relation("PurchaseDebitNoteCreatedBy")
  createdCashExpenses   CashExpense[]       @relation("CashExpenseCreatedBy")
  createdCustomerPayments CustomerPayment[]    @relation("CustomerPaymentCreatedBy")
  createdSupplierPayments SupplierPayment[]    @relation("SupplierPaymentCreatedBy")
  createdCustomerRefunds  CustomerRefund[]     @relation("CustomerRefundCreatedBy")
  createdSupplierRefunds  SupplierRefund[]     @relation("SupplierRefundCreatedBy")
  createdBankTransfers    BankTransfer[]       @relation("BankTransferCreatedBy")
  importedBankStatements   BankStatementImport[] @relation("BankStatementImportImportedBy")
  createdBankReconciliations BankReconciliation[] @relation("BankReconciliationCreatedBy")
  closedBankReconciliations  BankReconciliation[] @relation("BankReconciliationClosedBy")
  voidedBankReconciliations  BankReconciliation[] @relation("BankReconciliationVoidedBy")
  reversedCreditNoteAllocations CreditNoteAllocation[] @relation("CreditNoteAllocationReversedBy")
  reversedPurchaseDebitNoteAllocations PurchaseDebitNoteAllocation[] @relation("PurchaseDebitNoteAllocationReversedBy")
  reversedCustomerPaymentUnappliedAllocations CustomerPaymentUnappliedAllocation[] @relation("CustomerPaymentUnappliedAllocationReversedBy")
  reversedSupplierPaymentUnappliedAllocations SupplierPaymentUnappliedAllocation[] @relation("SupplierPaymentUnappliedAllocationReversedBy")
  generatedDocuments      GeneratedDocument[]  @relation("GeneratedDocumentGeneratedBy")
}

model Organization {
  id                         String                      @id @default(uuid()) @db.Uuid
  name                       String
  legalName                  String?
  taxNumber                  String?
  countryCode                String                      @default("SA")
  baseCurrency               String                      @default("SAR")
  timezone                   String                      @default("Asia/Riyadh")
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  memberships                OrganizationMember[]
  roles                      Role[]
  branches                   Branch[]
  contacts                   Contact[]
  accounts                   Account[]
  bankAccountProfiles        BankAccountProfile[]
  bankTransfers              BankTransfer[]
  bankStatementImports       BankStatementImport[]
  bankStatementTransactions  BankStatementTransaction[]
  bankReconciliations        BankReconciliation[]
  bankReconciliationItems    BankReconciliationItem[]
  taxRates                   TaxRate[]
  items                      Item[]
  salesInvoices              SalesInvoice[]
  salesInvoiceLines          SalesInvoiceLine[]
  creditNotes                CreditNote[]
  creditNoteLines            CreditNoteLine[]
  creditNoteAllocations      CreditNoteAllocation[]
  purchaseOrders             PurchaseOrder[]
  purchaseOrderLines         PurchaseOrderLine[]
  purchaseBills              PurchaseBill[]
  purchaseBillLines          PurchaseBillLine[]
  purchaseDebitNotes         PurchaseDebitNote[]
  purchaseDebitNoteLines     PurchaseDebitNoteLine[]
  purchaseDebitNoteAllocations PurchaseDebitNoteAllocation[]
  cashExpenses               CashExpense[]
  cashExpenseLines           CashExpenseLine[]
  customerPayments           CustomerPayment[]
  customerPaymentAllocations CustomerPaymentAllocation[]
  customerPaymentUnappliedAllocations CustomerPaymentUnappliedAllocation[]
  supplierPayments           SupplierPayment[]
  supplierPaymentAllocations SupplierPaymentAllocation[]
  supplierPaymentUnappliedAllocations SupplierPaymentUnappliedAllocation[]
  customerRefunds            CustomerRefund[]
  supplierRefunds            SupplierRefund[]
  journalEntries             JournalEntry[]
  journalLines               JournalLine[]
  fiscalPeriods              FiscalPeriod[]
  auditLogs                  AuditLog[]
  numberSequences            NumberSequence[]
  documentSettings           OrganizationDocumentSettings?
  generatedDocuments         GeneratedDocument[]
  zatcaProfile               ZatcaOrganizationProfile?
  zatcaEgsUnits              ZatcaEgsUnit[]
  zatcaInvoiceMetadata       ZatcaInvoiceMetadata[]
  zatcaSubmissionLogs        ZatcaSubmissionLog[]
}

model OrganizationDocumentSettings {
  id                       String       @id @default(uuid()) @db.Uuid
  organizationId           String       @unique @db.Uuid
  invoiceTitle             String       @default("Tax Invoice")
  receiptTitle             String       @default("Payment Receipt")
  statementTitle           String       @default("Customer Statement")
  footerText               String       @default("Generated by LedgerByte")
  primaryColor             String?
  accentColor              String?
  showTaxNumber            Boolean      @default(true)
  showPaymentSummary       Boolean      @default(true)
  showNotes                Boolean      @default(true)
  showTerms                Boolean      @default(true)
  defaultInvoiceTemplate   String       @default("standard")
  defaultReceiptTemplate   String       @default("standard")
  defaultStatementTemplate String       @default("standard")
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model GeneratedDocument {
  id              String                  @id @default(uuid()) @db.Uuid
  organizationId  String                  @db.Uuid
  documentType    DocumentType
  sourceType      String
  sourceId        String
  documentNumber  String
  filename        String
  mimeType        String                  @default("application/pdf")
  storageProvider String                  @default("database")
  storageKey      String?
  contentBase64   String?                 @db.Text
  contentHash     String
  sizeBytes       Int
  status          GeneratedDocumentStatus @default(GENERATED)
  generatedById   String?                 @db.Uuid
  generatedAt     DateTime                @default(now())
  createdAt       DateTime                @default(now())
  organization    Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generatedBy     User?                   @relation("GeneratedDocumentGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, documentType])
  @@index([organizationId, sourceType, sourceId])
  @@index([organizationId, status])
  @@index([generatedById])
}

model ZatcaOrganizationProfile {
  id                      String                  @id @default(uuid()) @db.Uuid
  organizationId          String                  @unique @db.Uuid
  environment             ZatcaEnvironment        @default(SANDBOX)
  registrationStatus      ZatcaRegistrationStatus @default(NOT_CONFIGURED)
  sellerName              String?
  vatNumber               String?
  companyIdType           String?
  companyIdNumber         String?
  buildingNumber          String?
  streetName              String?
  district                String?
  city                    String?
  postalCode              String?
  countryCode             String                  @default("SA")
  additionalAddressNumber String?
  businessCategory        String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  organization            Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  egsUnits                ZatcaEgsUnit[]

  @@index([organizationId])
}

model ZatcaEgsUnit {
  id                   String                  @id @default(uuid()) @db.Uuid
  organizationId       String                  @db.Uuid
  profileId            String                  @db.Uuid
  name                 String
  environment          ZatcaEnvironment
  status               ZatcaRegistrationStatus @default(DRAFT)
  deviceSerialNumber   String
  solutionName         String                  @default("LedgerByte")
  csrPem               String?                 @db.Text
  /// TODO: production must store private keys in a secrets manager/KMS, not in the database.
  privateKeyPem        String?                 @db.Text
  complianceCsidPem    String?                 @db.Text
  productionCsidPem    String?                 @db.Text
  certificateRequestId String?
  lastInvoiceHash      String?
  lastIcv              Int                     @default(0)
  isActive             Boolean                 @default(false)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  organization         Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  profile              ZatcaOrganizationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  invoiceMetadata      ZatcaInvoiceMetadata[]
  submissionLogs       ZatcaSubmissionLog[]

  @@unique([organizationId, deviceSerialNumber])
  @@index([organizationId])
  @@index([profileId])
  @@index([organizationId, isActive])
}

model ZatcaInvoiceMetadata {
  id                  String             @id @default(uuid()) @db.Uuid
  organizationId      String             @db.Uuid
  invoiceId           String             @unique @db.Uuid
  zatcaInvoiceType    ZatcaInvoiceType
  zatcaStatus         ZatcaInvoiceStatus @default(NOT_SUBMITTED)
  invoiceUuid         String             @unique @default(uuid()) @db.Uuid
  icv                 Int?
  previousInvoiceHash String?
  invoiceHash         String?
  qrCodeBase64        String?            @db.Text
  xmlBase64           String?            @db.Text
  xmlHash             String?
  egsUnitId           String?            @db.Uuid
  generatedAt         DateTime?
  clearedAt           DateTime?
  reportedAt          DateTime?
  rejectedAt          DateTime?
  lastErrorCode       String?
  lastErrorMessage    String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice             SalesInvoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  egsUnit             ZatcaEgsUnit?      @relation(fields: [egsUnitId], references: [id], onDelete: SetNull)
  submissionLogs      ZatcaSubmissionLog[]

  @@index([organizationId])
  @@index([organizationId, zatcaStatus])
  @@index([egsUnitId])
}

model ZatcaSubmissionLog {
  id                   String                 @id @default(uuid()) @db.Uuid
  organizationId       String                 @db.Uuid
  invoiceMetadataId    String?                @db.Uuid
  egsUnitId            String?                @db.Uuid
  submissionType       ZatcaSubmissionType
  status               ZatcaSubmissionStatus
  requestUrl           String?
  requestPayloadBase64 String?                @db.Text
  responsePayloadBase64 String?               @db.Text
  responseCode         String?
  errorCode            String?
  errorMessage         String?
  submittedAt          DateTime               @default(now())
  completedAt          DateTime?
  createdAt            DateTime               @default(now())
  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceMetadata      ZatcaInvoiceMetadata?  @relation(fields: [invoiceMetadataId], references: [id], onDelete: Cascade)
  egsUnit              ZatcaEgsUnit?          @relation(fields: [egsUnitId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([invoiceMetadataId])
  @@index([egsUnitId])
  @@index([organizationId, status])
}

model Role {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @db.Uuid
  name           String
  permissions    Json
  isSystem       Boolean              @default(false)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        OrganizationMember[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model OrganizationMember {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid
  userId         String           @db.Uuid
  roleId         String           @db.Uuid
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role             @relation(fields: [roleId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
}

model Branch {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid
  name           String
  displayName    String?
  phone          String?
  taxNumber      String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  countryCode    String         @default("SA")
  postalCode     String?
  isDefault      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesInvoices  SalesInvoice[]
  creditNotes    CreditNote[]
  purchaseOrders PurchaseOrder[]
  purchaseBills  PurchaseBill[]
  purchaseDebitNotes PurchaseDebitNote[]
  cashExpenses   CashExpense[]

  @@index([organizationId])
}

model Contact {
  id               String            @id @default(uuid()) @db.Uuid
  organizationId   String            @db.Uuid
  type             ContactType       @default(CUSTOMER)
  name             String
  displayName      String?
  email            String?
  phone            String?
  taxNumber        String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  countryCode      String            @default("SA")
  postalCode       String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesInvoices    SalesInvoice[]    @relation("SalesInvoiceCustomer")
  creditNotes      CreditNote[]      @relation("CreditNoteCustomer")
  purchaseOrders   PurchaseOrder[]   @relation("PurchaseOrderSupplier")
  purchaseBills    PurchaseBill[]    @relation("PurchaseBillSupplier")
  purchaseDebitNotes PurchaseDebitNote[] @relation("PurchaseDebitNoteSupplier")
  cashExpenses     CashExpense[]     @relation("CashExpenseContact")
  customerPayments CustomerPayment[] @relation("CustomerPaymentCustomer")
  supplierPayments SupplierPayment[] @relation("SupplierPaymentSupplier")
  customerRefunds  CustomerRefund[]  @relation("CustomerRefundCustomer")
  supplierRefunds  SupplierRefund[]  @relation("SupplierRefundSupplier")

  @@index([organizationId])
  @@index([organizationId, type])
}

model Account {
  id                String             @id @default(uuid()) @db.Uuid
  organizationId    String             @db.Uuid
  parentId          String?            @db.Uuid
  code              String
  name              String
  type              AccountType
  description       String?
  allowPosting      Boolean            @default(true)
  isSystem          Boolean            @default(false)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent            Account?           @relation("AccountTree", fields: [parentId], references: [id])
  children          Account[]          @relation("AccountTree")
  journalLines      JournalLine[]
  itemRevenueItems  Item[]             @relation("ItemRevenueAccount")
  itemExpenseItems  Item[]             @relation("ItemExpenseAccount")
  salesInvoiceLines SalesInvoiceLine[]
  creditNoteLines   CreditNoteLine[]
  purchaseOrderLines PurchaseOrderLine[]
  purchaseBillLines PurchaseBillLine[]
  purchaseDebitNoteLines PurchaseDebitNoteLine[]
  cashExpenseLines  CashExpenseLine[]
  cashExpensePayments CashExpense[]   @relation("CashExpensePaidThroughAccount")
  customerPayments  CustomerPayment[]  @relation("CustomerPaymentAccount")
  supplierPayments  SupplierPayment[]  @relation("SupplierPaymentAccount")
  customerRefunds   CustomerRefund[]   @relation("CustomerRefundAccount")
  supplierRefunds   SupplierRefund[]   @relation("SupplierRefundAccount")
  bankAccountProfile BankAccountProfile?
  bankTransfersFrom BankTransfer[]      @relation("BankTransferFromAccount")
  bankTransfersTo   BankTransfer[]      @relation("BankTransferToAccount")
  categorizedBankStatementTransactions BankStatementTransaction[] @relation("BankStatementTransactionCategorizedAccount")

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([parentId])
}

model BankAccountProfile {
  id                  String            @id @default(uuid()) @db.Uuid
  organizationId      String            @db.Uuid
  accountId           String            @unique @db.Uuid
  type                BankAccountType
  status              BankAccountStatus @default(ACTIVE)
  displayName         String
  bankName            String?
  accountNumberMasked String?
  ibanMasked          String?
  currency            String            @default("SAR")
  openingBalance      Decimal           @default(0) @db.Decimal(20, 4)
  openingBalanceDate  DateTime?
  openingBalanceJournalEntryId String?  @unique @db.Uuid
  openingBalancePostedAt DateTime?
  notes               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  organization        Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account             Account           @relation(fields: [accountId], references: [id])
  openingBalanceJournalEntry JournalEntry? @relation("BankAccountOpeningBalanceJournal", fields: [openingBalanceJournalEntryId], references: [id])
  outgoingTransfers   BankTransfer[]    @relation("BankTransferFromProfile")
  incomingTransfers   BankTransfer[]    @relation("BankTransferToProfile")
  statementImports    BankStatementImport[]
  statementTransactions BankStatementTransaction[]
  reconciliations     BankReconciliation[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, type])
}

model BankTransfer {
  id                         String             @id @default(uuid()) @db.Uuid
  organizationId             String             @db.Uuid
  transferNumber             String
  fromBankAccountProfileId   String             @db.Uuid
  toBankAccountProfileId     String             @db.Uuid
  fromAccountId              String             @db.Uuid
  toAccountId                String             @db.Uuid
  transferDate               DateTime
  currency                   String             @default("SAR")
  status                     BankTransferStatus @default(POSTED)
  amount                     Decimal            @db.Decimal(20, 4)
  description                String?
  journalEntryId             String?            @unique @db.Uuid
  voidReversalJournalEntryId String?            @unique @db.Uuid
  createdById                String?            @db.Uuid
  postedAt                   DateTime?
  voidedAt                   DateTime?
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  organization               Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromBankAccountProfile     BankAccountProfile @relation("BankTransferFromProfile", fields: [fromBankAccountProfileId], references: [id])
  toBankAccountProfile       BankAccountProfile @relation("BankTransferToProfile", fields: [toBankAccountProfileId], references: [id])
  fromAccount                Account            @relation("BankTransferFromAccount", fields: [fromAccountId], references: [id])
  toAccount                  Account            @relation("BankTransferToAccount", fields: [toAccountId], references: [id])
  journalEntry               JournalEntry?      @relation("BankTransferJournal", fields: [journalEntryId], references: [id])
  voidReversalJournalEntry   JournalEntry?      @relation("BankTransferVoidReversalJournal", fields: [voidReversalJournalEntryId], references: [id])
  createdBy                  User?              @relation("BankTransferCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([organizationId, transferNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([fromBankAccountProfileId])
  @@index([toBankAccountProfileId])
}

model BankStatementImport {
  id                      String                    @id @default(uuid()) @db.Uuid
  organizationId          String                    @db.Uuid
  bankAccountProfileId    String                    @db.Uuid
  importedById            String?                   @db.Uuid
  filename                String
  sourceType              String                    @default("CSV")
  status                  BankStatementImportStatus @default(IMPORTED)
  statementStartDate      DateTime?
  statementEndDate        DateTime?
  openingStatementBalance Decimal?                  @db.Decimal(20, 4)
  closingStatementBalance Decimal?                  @db.Decimal(20, 4)
  rowCount                Int
  importedAt              DateTime                  @default(now())
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  organization            Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccountProfile      BankAccountProfile        @relation(fields: [bankAccountProfileId], references: [id])
  importedBy              User?                     @relation("BankStatementImportImportedBy", fields: [importedById], references: [id], onDelete: SetNull)
  transactions            BankStatementTransaction[]

  @@index([organizationId])
  @@index([bankAccountProfileId])
  @@index([organizationId, status])
  @@index([organizationId, importedAt])
}

model BankStatementTransaction {
  id                    String                         @id @default(uuid()) @db.Uuid
  organizationId        String                         @db.Uuid
  importId              String                         @db.Uuid
  bankAccountProfileId  String                         @db.Uuid
  transactionDate       DateTime
  description           String
  reference             String?
  type                  BankStatementTransactionType
  amount                Decimal                        @db.Decimal(20, 4)
  status                BankStatementTransactionStatus @default(UNMATCHED)
  matchedJournalLineId  String?                        @db.Uuid
  matchedJournalEntryId String?                        @db.Uuid
  matchType             BankStatementMatchType?
  categorizedAccountId  String?                        @db.Uuid
  createdJournalEntryId String?                        @db.Uuid
  ignoredReason         String?
  rawData               Json?
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt

  skippedBy             User?                         @relation("OnboardingChecklistItemSkippedBy", fields: [skippedById], references: [id], onDelete: SetNull)
  reopenedBy            User?                         @relation("OnboardingChecklistItemReopenedBy", fields: [reopenedById], references: [id], onDelete: SetNull)
  createdBy             User?                         @relation("OnboardingChecklistItemCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy             User?                         @relation("OnboardingChecklistItemUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  events                OnboardingChecklistEvent[]

  @@unique([onboardingChecklistId, itemKey])
  @@index([organizationId])
  @@index([branchId])
  @@index([organizationId, branchId])
  @@index([onboardingChecklistId])
  @@index([organizationId, status])
  @@index([organizationId, branchId, status])
  @@index([itemKey])
  @@index([routeKey])
  @@index([setupProgressKey])
  @@index([completedById])
  @@index([skippedById])
  @@index([reopenedById])
  @@index([createdById])
  @@index([updatedById])
}

model OnboardingChecklistEvent {
  id                        String                       @id @default(uuid()) @db.Uuid
  organizationId            String                       @db.Uuid
  branchId                  String?                      @db.Uuid
  onboardingProfileId       String?                      @db.Uuid
  onboardingChecklistId     String?                      @db.Uuid
  onboardingChecklistItemId String?                      @db.Uuid
  eventType                 OnboardingChecklistEventType
  actorUserId               String?                      @db.Uuid
  previousValueJson         Json?
  nextValueJson             Json?
  payloadJson               Json?
  reason                    String?
  createdAt                 DateTime                     @default(now())
  organization              Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch                    Branch?                      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  onboardingProfile         OnboardingProfile?           @relation(fields: [onboardingProfileId], references: [id], onDelete: SetNull)
  onboardingChecklist       OnboardingChecklist?         @relation(fields: [onboardingChecklistId], references: [id], onDelete: SetNull)
  onboardingChecklistItem   OnboardingChecklistItem?     @relation(fields: [onboardingChecklistItemId], references: [id], onDelete: SetNull)
  actorUser                 User?                        @relation("OnboardingChecklistEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([branchId])
  @@index([organizationId, branchId])
  @@index([organizationId, eventType])
  @@index([organizationId, createdAt])
  @@index([onboardingProfileId])
  @@index([onboardingChecklistId])
  @@index([onboardingChecklistItemId])
  @@index([actorUserId])
}

model OnboardingTemplateVersion {
  id           String                          @id @default(uuid()) @db.Uuid
  version      String
  archetypeKey String
  itemKeys     Json
  status       OnboardingTemplateVersionStatus @default(DRAFT)
  activatedAt  DateTime?
  archivedAt   DateTime?
  createdById  String?                         @db.Uuid
  updatedById  String?                         @db.Uuid
  createdAt    DateTime                        @default(now())
  updatedAt    DateTime                        @updatedAt
  createdBy    User?                           @relation("OnboardingTemplateVersionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?                           @relation("OnboardingTemplateVersionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([version, archetypeKey])
  @@index([version])
  @@index([archetypeKey])
  @@index([archetypeKey, status])
  @@index([status])
  @@index([createdById])
  @@index([updatedById])
}

model AuditLog {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  actorUserId    String?      @db.Uuid
  action         String
  entityType     String
  entityId       String
  before         Json?
  after          Json?
  ipAddress      String?
  userAgent      String?
  requestId      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser      User?        @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([requestId])
}

model ApiIdempotencyRecord {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  route          String
  keyHash        String
  requestHash    String
  responseJson   Json
  statusCode     Int
  requestId      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, route, keyHash])
  @@index([organizationId])
  @@index([requestId])
}

model WebhookEndpoint {
  id                       String                   @id @default(uuid()) @db.Uuid
  organizationId           String                   @db.Uuid
  name                     String
  status                   String                   @default("DISABLED")
  targetUrlHost            String?
  redactedTargetUrl        String?
  eventTypes               Json
  signingSecretStorageMode String                   @default("NOT_STORED")
  signingSecretConfigured  Boolean                  @default(false)
  createdById              String?                  @db.Uuid
  requestId                String?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  organization             Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events                   WebhookEvent[]
  deliveryAttempts         WebhookDeliveryAttempt[]

  @@index([organizationId])
  @@index([requestId])
}

model WebhookEvent {
  id                 String                   @id @default(uuid()) @db.Uuid
  organizationId     String                   @db.Uuid
  webhookEndpointId  String?                  @db.Uuid
  eventType          String
  status             String                   @default("PENDING")
  safePayloadSummary Json
  requestId          String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  endpoint           WebhookEndpoint?         @relation(fields: [webhookEndpointId], references: [id], onDelete: SetNull)
  deliveryAttempts   WebhookDeliveryAttempt[]

  @@index([organizationId])
  @@index([webhookEndpointId])
  @@index([requestId])
}

model WebhookDeliveryAttempt {
  id                String           @id @default(uuid()) @db.Uuid
  organizationId    String           @db.Uuid
  webhookEventId    String           @db.Uuid
  webhookEndpointId String?          @db.Uuid
  attemptNumber     Int
  status            String           @default("QUEUED")
  nextAttemptAt     DateTime?
  responseSummary   Json?
  requestId         String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event             WebhookEvent     @relation(fields: [webhookEventId], references: [id], onDelete: Cascade)
  endpoint          WebhookEndpoint? @relation(fields: [webhookEndpointId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([webhookEventId])
  @@index([webhookEndpointId])
  @@index([requestId])
}

model EventOutboxItem {
  id                 String       @id @default(uuid()) @db.Uuid
  organizationId     String       @db.Uuid
  eventType          String
  aggregateType      String
  aggregateId        String
  status             String       @default("PENDING")
  safePayloadSummary Json
  requestId          String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([eventType])
  @@index([requestId])
}

model AuditLogRetentionSettings {
  id                        String       @id @default(uuid()) @db.Uuid
  organizationId            String       @unique @db.Uuid
  retentionDays             Int          @default(2555)
  autoPurgeEnabled          Boolean      @default(false)
  exportBeforePurgeRequired Boolean      @default(true)
  updatedById               String?      @db.Uuid
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
  organization              Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  updatedBy                 User?        @relation("AuditLogRetentionSettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([updatedById])
}

model NumberSequence {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String              @db.Uuid
  scope          NumberSequenceScope
  prefix         String
  nextNumber     Int                 @default(1)
  padding        Int                 @default(6)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, scope])
  @@index([organizationId])
}

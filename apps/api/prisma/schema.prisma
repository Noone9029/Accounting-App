model JournalEntry {
  id                    String             @id @default(uuid()) @db.Uuid
  organizationId        String             @db.Uuid
  entryNumber           String
  status                JournalEntryStatus @default(DRAFT)
  entryDate             DateTime
  description           String
  reference             String?
  currency              String             @default("SAR")
  totalDebit            Decimal            @default(0) @db.Decimal(20, 4)
  totalCredit           Decimal            @default(0) @db.Decimal(20, 4)
  postedAt              DateTime?
  postedById            String?            @db.Uuid
  createdById           String?            @db.Uuid
  reversalOfId          String?            @unique @db.Uuid
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  organization          Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  postedBy              User?              @relation("PostedBy", fields: [postedById], references: [id])
  createdBy             User?              @relation("CreatedBy", fields: [createdById], references: [id])
  reversalOf            JournalEntry?      @relation("JournalReversal", fields: [reversalOfId], references: [id])
  reversedBy            JournalEntry?      @relation("JournalReversal")
  salesInvoice          SalesInvoice?      @relation("SalesInvoiceJournal")
  voidedSalesInvoice    SalesInvoice?      @relation("SalesInvoiceReversalJournal")
  creditNote            CreditNote?        @relation("CreditNoteJournal")
  voidedCreditNote      CreditNote?        @relation("CreditNoteReversalJournal")
  purchaseBill          PurchaseBill?      @relation("PurchaseBillJournal")
  voidedPurchaseBill    PurchaseBill?      @relation("PurchaseBillReversalJournal")
  customerPayment       CustomerPayment?   @relation("CustomerPaymentJournal")
  voidedCustomerPayment CustomerPayment?   @relation("CustomerPaymentVoidReversalJournal")
  supplierPayment       SupplierPayment?   @relation("SupplierPaymentJournal")
  voidedSupplierPayment SupplierPayment?   @relation("SupplierPaymentVoidReversalJournal")
  customerRefund        CustomerRefund?    @relation("CustomerRefundJournal")
  voidedCustomerRefund  CustomerRefund?    @relation("CustomerRefundVoidReversalJournal")
  lines                 JournalLine[]

  @@unique([organizationId, entryNumber])
  @@index([organizationId])
  @@index([status])
}

model JournalLine {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  journalEntryId String       @db.Uuid
  accountId      String       @db.Uuid
  taxRateId      String?      @db.Uuid
  lineNumber     Int
  description    String?
  debit          Decimal      @default(0) @db.Decimal(20, 4)
  credit         Decimal      @default(0) @db.Decimal(20, 4)
  currency       String       @default("SAR")
  exchangeRate   Decimal      @default(1) @db.Decimal(18, 8)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        Account      @relation(fields: [accountId], references: [id])
  taxRate        TaxRate?     @relation(fields: [taxRateId], references: [id])

  @@index([organizationId])
  @@index([journalEntryId])
  @@index([accountId])
}


{
  "name": "@ledgerbyte/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch --entryFile apps/api/src/main",
    "build": "nest build",
    "start": "node dist/apps/api/src/main.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --config jest.config.cjs",
    "smoke:accounting": "tsx scripts/smoke-accounting.ts",
    "zatca:csr-dry-run": "tsx scripts/zatca-csr-dry-run.ts",
    "zatca:csr-local-generate": "tsx scripts/zatca-csr-local-generate.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1047.0",
    "@ledgerbyte/accounting-core": "workspace:*",
    "@ledgerbyte/pdf-core": "workspace:*",
    "@ledgerbyte/shared": "workspace:*",
    "@ledgerbyte/zatca-core": "workspace:*",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "decimal.js": "^10.5.0",
    "express": "5.2.1",
    "nodemailer": "^8.0.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/testing": "^11.1.0",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.0",
    "@types/nodemailer": "^8.0.0",
    "jest": "^30.0.0",
    "prisma": "^6.0.0",
    "ts-jest": "^29.3.4",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}

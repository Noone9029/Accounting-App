{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "main": false,
      "codex/**": false
    }
  },
  "buildCommand": "corepack pnpm --filter @ledgerbyte/api db:generate",
  "functions": {
    "api/index.ts": {
      "maxDuration": 70,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/internal/recurring-worker",
      "schedule": "*/5 * * * *"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ]
}

DATABASE_URL="postgresql://accounting:accounting@localhost:5432/accounting?schema=public"
# Optional but recommended for Supabase/Prisma migrations. Use the direct database URL here.
DIRECT_URL="postgresql://accounting:accounting@localhost:5432/accounting?schema=public"
PRISMA_TRANSACTION_MAX_WAIT_MS="10000"
PRISMA_TRANSACTION_TIMEOUT_MS="20000"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="replace-me-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"
# Security maintenance cleanup. Conservative defaults are used when these are unset.
AUTH_SESSION_CLEANUP_EXPIRED_RETENTION_DAYS="30"
AUTH_SESSION_CLEANUP_REVOKED_RETENTION_DAYS="30"
LOGIN_RATE_LIMIT_CLEANUP_RETENTION_DAYS="7"
SECURITY_CLEANUP_BATCH_SIZE="500"
API_PORT="4000"
WEB_PORT="3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
CORS_ORIGIN="http://localhost:3000"
APP_WEB_URL="http://localhost:3000"
# Public API v1 productization is disabled by default. These flags are readiness placeholders only.
LEDGERBYTE_PUBLIC_API_ENABLED="false"
LEDGERBYTE_PUBLIC_API_RATE_LIMIT_ENABLED="false"
LEDGERBYTE_PUBLIC_API_RATE_LIMIT_STRATEGY="DISABLED"
LEDGERBYTE_PUBLIC_API_KEYS_ENABLED="false"
LEDGERBYTE_PUBLIC_API_OAUTH_ENABLED="false"
# Supported modes: mock, smtp-disabled, smtp. Default mock never sends real email.
EMAIL_PROVIDER="mock"
EMAIL_FROM="no-reply@ledgerbyte.local"
EMAIL_REPLY_TO=""
# Disabled by default: diagnostics returns a skipped plan and sends no email.
LEDGERBYTE_EMAIL_DIAGNOSTICS_SEND_ENABLED="false"
LEDGERBYTE_EMAIL_DIAGNOSTICS_ALLOWED_RECIPIENTS=""
LEDGERBYTE_EMAIL_DIAGNOSTICS_ALLOWED_DOMAINS="example.test,ledgerbyte.local"
# Disabled by default: retry processor returns a skipped plan and sends no email.
LEDGERBYTE_EMAIL_RETRY_PROCESSOR_ENABLED="false"
# Disabled by default: scheduled worker runs return a skipped plan and sends no email.
LEDGERBYTE_EMAIL_RETRY_WORKER_ENABLED="false"
# Disabled by default: signed provider webhooks are rejected/unverified unless explicitly configured.
EMAIL_PROVIDER_WEBHOOK_VERIFICATION_ENABLED="false"
EMAIL_PROVIDER_WEBHOOK_SECRET=""
EMAIL_PROVIDER_WEBHOOK_ALLOWED_PROVIDERS=""
# Required only when EMAIL_PROVIDER=smtp. Do not commit real secret values.
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_SECURE="false"
ZATCA_ADAPTER_MODE="mock"
ZATCA_ENABLE_REAL_NETWORK="false"
ZATCA_SANDBOX_BASE_URL=""
ZATCA_SIMULATION_BASE_URL=""
ZATCA_PRODUCTION_BASE_URL=""
ZATCA_SDK_EXECUTION_ENABLED="false"
ZATCA_HASH_MODE="local"
ZATCA_SDK_JAR_PATH=""
ZATCA_SDK_CONFIG_DIR=""
ZATCA_SDK_WORK_DIR=""
ZATCA_SDK_JAVA_BIN="java"
ZATCA_SDK_TIMEOUT_MS="30000"
# Supported attachment storage providers: database, s3. Default database keeps local/dev simple.
ATTACHMENT_STORAGE_PROVIDER="database"
GENERATED_DOCUMENT_STORAGE_PROVIDER="database"
ATTACHMENT_MAX_SIZE_MB="10"
# Required only when ATTACHMENT_STORAGE_PROVIDER=s3. Do not commit real secret values.
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"
S3_PUBLIC_BASE_URL=""
